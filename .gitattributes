###############################################################################
# Set default behavior to automatically normalize line endings.
###############################################################################
* text=auto

###############################################################################
# Force LF for source code (recommended for cross-platform & CI)
###############################################################################
*.sol     text eol=lf
*.js      text eol=lf
*.ts      text eol=lf
*.json    text eol=lf
*.md      text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.sh      text eol=lf

# --- .NET / C# ---
*.cs      text eol=lf
*.csproj text eol=lf
*.sln    text eol=lf
*.props  text eol=lf
*.targets text eol=lf

###############################################################################
# Windows-specific scripts
###############################################################################
*.bat     text eol=crlf
*.cmd     text eol=crlf

